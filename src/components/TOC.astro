---
import type { MarkdownHeading } from "astro";

interface Props {
	headings: MarkdownHeading[];
	title?: string;
}

const { headings, title } = Astro.props;
const titleSlug = title ? title.toLowerCase().replaceAll(/\s/g, "-") : "";
---
<nav>
  <h2>Contents</h2>
  <ul>
    {title ? <li>
      <a href={`#${titleSlug}`}>{title}</a>
    </li> : <></>}
    {headings.map((heading) => (
      <li>
        <a href={`#${heading.slug}`}>{heading.text}</a>
      </li>
    ))}
  </ul>
</nav>

<script define:vars={{ headings, titleSlug }}>
const observer = new IntersectionObserver(
  (entries) => {
    entries.forEach((entry) => {
      console.log(entry);
      const id = entry.target.getAttribute("id");
      if (entry.intersectionRatio > 0) {
        document.querySelector(`a.current`)?.classList.remove("current");
        document.querySelector(`a[href="#${id}"]`)?.classList.add("current");
      }
    });
  },
  { rootMargin: "0px 0px -70% 0px" }
);

document.addEventListener("DOMContentLoaded", () => {
  const element = document.getElementById(titleSlug);
  if (element) {
    observer.observe(element);
  }
  headings.forEach((heading) => {
    const element = document.getElementById(heading.slug);
    observer.observe(element);
  });
});
</script>

<style>
  nav {
    position: fixed;
    width: 15rem;
    padding-top: 1rem;
    padding-bottom: 0.5rem;
    margin-left: -17rem;
    text-align: left;
    background: var(--background);
    font-size: 12pt;
  }

  @media (max-width: 800px) {
    nav {
      position: static;
      width: auto;
      margin: 0;
      padding: 0;
    }
  }

  h2 {
    font-size: 18pt;
    margin-bottom: 0;
  }

  ul {
    padding: 0;
    margin-top: 0.25rem;
  }

  li {
    list-style: none;
    margin: 0.2rem 0;
  }

  a {
    text-decoration: none;
    color: var(--color);
    transition: margin-left;
  }

  a:hover {
    text-decoration: underline;
  }

  a.current::before {
    display: inline;
    content: "▸";
    margin-right: 0.25rem;
    margin-left: -1rem;
  }
</style>
