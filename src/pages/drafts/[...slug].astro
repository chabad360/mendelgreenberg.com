---
import { getCollection, render } from "astro:content";
import Post from "../../layouts/Post.astro";

export async function getStaticPaths() {
	const posts = await getCollection("posts");

	return posts
		.filter((p) => !p.data.publish)
		.map((post) => ({
			params: { slug: post.id },
			props: { post },
		}));
}

const { post } = Astro.props;
---

<Post post={post} />
