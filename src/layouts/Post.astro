---
import { type CollectionEntry, render } from "astro:content";
import getReadingTime from "reading-time";
import Contents from "../components/Contents.astro";
import TOC from "../components/TOC.astro";
import Layout from "./Layout.astro";

interface Props {
	post: CollectionEntry<"posts">;
}

const { post } = Astro.props;

const { Content, headings } = await render(post);
const titleSlug = post.data.title.toLowerCase().replaceAll(/\s/g, "-");
---

<Layout title={post.data.title} item={post} >
    <Contents>
      <article>
        <TOC headings={headings} title={post.data.includeTitleInTOC ? post.data.title : undefined } />
        <small><time datetime={post.data.date.toISOString()}>{post.data.date.toLocaleDateString()}</time> &middot; {getReadingTime(post.body!).text}</small>
        <h1 id={titleSlug}>{post.data.title}</h1>
        <Content />
      </article>
      <script src="https://giscus.app/client.js"
              data-repo="chabad360/mendelgreenberg.com"
              data-repo-id="R_kgDOSBEpeg"
              data-category="Posts"
              data-category-id="DIC_kwDOSBEpes4C6uHC"
              data-mapping="pathname"
              data-strict="0"
              data-reactions-enabled="1"
              data-emit-metadata="0"
              data-input-position="top"
              data-lang="en"
              data-loading="lazy"
              crossorigin="anonymous"
              data-theme="preferred_color_scheme"
              async>
      </script>
    </Contents>
</Layout>
